---
// Página estática — el ID del paciente se lee desde ?id= en el URL via JS
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Reporte InBody — Iratxe Menéndez Nutrición</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body class="antialiased bg-slate-50 text-slate-900 min-h-screen">

    <header class="bg-white border-b border-slate-200 sticky top-0 z-10">
      <div class="max-w-2xl mx-auto px-4 h-14 flex items-center justify-between">
        <div>
          <p class="font-bold text-sm leading-tight">Iratxe Menéndez</p>
          <p class="text-xs text-slate-500">Nutrición & Composición Corporal</p>
        </div>
        <a href="https://wa.me/5219996690192" class="text-xs bg-green-500 text-white rounded-full px-3 py-1.5 font-medium">
          📱 Contactar
        </a>
      </div>
    </header>

    <main class="max-w-2xl mx-auto px-4 py-8">

      <div id="loading" class="text-center py-20">
        <div class="text-4xl mb-4">⏳</div>
        <p class="text-slate-500">Cargando tu reporte...</p>
      </div>

      <div id="error" class="hidden text-center py-20">
        <div class="text-4xl mb-4">🔍</div>
        <p class="text-slate-700 font-semibold">Reporte no encontrado</p>
        <p class="text-slate-500 text-sm mt-2">El enlace puede haber expirado o no es válido.</p>
        <a href="https://wa.me/5219996690192?text=Hola%20Iratxe%2C%20necesito%20mi%20reporte%20InBody"
           class="mt-6 inline-block bg-green-500 text-white rounded-xl px-5 py-2.5 font-medium text-sm">
          Solicitar reporte por WhatsApp
        </a>
      </div>

      <div id="report-data" class="hidden space-y-6">
        <div class="bg-white rounded-2xl border border-slate-200 p-5">
          <div class="flex items-start justify-between">
            <div>
              <h1 class="text-xl font-bold" id="patient-name">—</h1>
              <p class="text-sm text-slate-500" id="report-date">—</p>
            </div>
            <div class="text-right">
              <p class="text-xs text-slate-400 uppercase tracking-wide">Evaluación</p>
              <p class="font-semibold text-slate-700" id="evaluation-number">—</p>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div class="bg-white rounded-2xl border border-slate-200 p-4 text-center">
            <p class="text-xs text-slate-400 uppercase tracking-wide">Peso</p>
            <p class="text-3xl font-bold mt-1" id="weight">—</p>
            <p class="text-xs text-slate-400">kg</p>
          </div>
          <div class="bg-white rounded-2xl border border-slate-200 p-4 text-center">
            <p class="text-xs text-slate-400 uppercase tracking-wide">% Grasa</p>
            <p class="text-3xl font-bold mt-1" id="fat-percent">—</p>
            <p class="text-xs text-slate-400">%</p>
          </div>
          <div class="bg-white rounded-2xl border border-slate-200 p-4 text-center">
            <p class="text-xs text-slate-400 uppercase tracking-wide">Masa muscular</p>
            <p class="text-3xl font-bold mt-1" id="muscle-mass">—</p>
            <p class="text-xs text-slate-400">kg</p>
          </div>
          <div class="bg-white rounded-2xl border border-slate-200 p-4 text-center">
            <p class="text-xs text-slate-400 uppercase tracking-wide">IMC</p>
            <p class="text-3xl font-bold mt-1" id="bmi">—</p>
            <p class="text-xs text-slate-400">kg/m²</p>
          </div>
        </div>

        <div class="bg-white rounded-2xl border border-slate-200 p-5">
          <p class="text-xs text-slate-400 uppercase tracking-wide font-semibold mb-3">📝 Notas de tu nutrióloga</p>
          <p class="text-slate-700 text-sm leading-relaxed" id="notes">—</p>
        </div>

        <div class="bg-slate-900 rounded-2xl p-5 text-center text-white">
          <p class="font-semibold">¿Tienes dudas sobre tu reporte?</p>
          <a href="https://wa.me/5219996690192?text=Hola%20Iratxe%2C%20tengo%20dudas%20sobre%20mi%20reporte%20InBody"
             class="mt-3 inline-block bg-white text-slate-900 rounded-xl px-5 py-2.5 font-semibold text-sm">
            Hablar con Iratxe por WhatsApp
          </a>
        </div>
      </div>
    </main>

    <script>
      // Lee el ID desde ?id=XXX en la URL
      const params = new URLSearchParams(window.location.search);
      const reportId = params.get('id');

      // URL del Apps Script de Iratxe — pendiente desplegar
      // Reemplazar con la URL real al activar el Web App en Google Apps Script
      const APPS_SCRIPT_URL = 'https://script.google.com/macros/s/PENDING_SCRIPT_URL/exec';

      async function loadReport() {
        if (!reportId) {
          document.getElementById('loading').classList.add('hidden');
          document.getElementById('error').classList.remove('hidden');
          return;
        }
        try {
          const res = await fetch(`${APPS_SCRIPT_URL}?id=${encodeURIComponent(reportId)}`);
          if (!res.ok) throw new Error('not found');
          const data = await res.json();
          if (!data || data.error) throw new Error('not found');

          document.getElementById('patient-name').textContent = data.nombre || '—';
          document.getElementById('report-date').textContent = data.fecha || '—';
          document.getElementById('evaluation-number').textContent = `Evaluación #${data.evaluacion || '—'}`;
          document.getElementById('weight').textContent = data.peso || '—';
          document.getElementById('fat-percent').textContent = data.grasaPct || '—';
          document.getElementById('muscle-mass').textContent = data.masaMuscular || '—';
          document.getElementById('bmi').textContent = data.imc || '—';
          document.getElementById('notes').textContent = data.notas || 'Sin notas adicionales.';

          document.getElementById('loading').classList.add('hidden');
          document.getElementById('report-data').classList.remove('hidden');
        } catch {
          document.getElementById('loading').classList.add('hidden');
          document.getElementById('error').classList.remove('hidden');
        }
      }

      loadReport();
    </script>
  </body>
</html>
