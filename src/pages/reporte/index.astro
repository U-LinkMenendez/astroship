---
// Página estática — el ID del paciente se lee desde ?id= en la URL via JS
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Reporte InBody — Iratxe Menéndez Nutrición</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: 'DM Sans', Arial, sans-serif; background: #fdf5f9; color: #1a2535; padding-bottom: 48px; }
      .header { background: linear-gradient(135deg, #1a2535 0%, #2d3748 100%); position: sticky; top: 0; z-index: 100; box-shadow: 0 4px 20px rgba(0,0,0,.2); }
      .header-inner { display: flex; align-items: center; justify-content: space-between; padding: 14px 18px; max-width: 640px; margin: 0 auto; }
      .logo-text { color: #fff; }
      .logo-name { font-family: 'Playfair Display', Georgia, serif; font-size: 15px; font-weight: 700; }
      .logo-sub { font-size: 9px; color: rgba(255,255,255,.6); letter-spacing: .5px; margin-top: 2px; }
      .accent-bar { height: 4px; background: linear-gradient(90deg, #E8317A, #F5A623); }
      .score-box { text-align: right; }
      .score-val { font-family: 'Playfair Display', Georgia, serif; font-size: 28px; font-weight: 700; color: #fff; }
      .score-lbl { font-size: 9px; color: rgba(255,255,255,.6); letter-spacing: .5px; margin-top: 2px; }
      .pac-band { background: linear-gradient(135deg,#fff,#fdf5f9); padding: 14px 18px; border-bottom: 1px solid #f0e8f4; max-width: 640px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; }
      .pac-nombre { font-family: 'Playfair Display', Georgia, serif; font-size: 17px; font-weight: 700; color: #E8317A; }
      .pac-info { font-size: 11px; color: #9aa5b4; margin-top: 3px; }
      .pac-fecha { text-align: right; font-size: 11px; color: #9aa5b4; }
      .pac-fecha strong { display: block; font-size: 13px; color: #1a2535; font-weight: 600; }
      .content { max-width: 640px; margin: 0 auto; padding: 16px; }
      .card { background: #fff; border-radius: 20px; padding: 20px 18px; margin-bottom: 16px; box-shadow: 0 4px 24px rgba(232,49,122,.06); border: 1px solid rgba(232,49,122,.08); }
      .card-title { display: flex; align-items: center; gap: 10px; margin-bottom: 18px; padding-bottom: 12px; border-bottom: 2px solid #fde8f1; font-family: 'Playfair Display', Georgia, serif; font-size: 14px; font-weight: 700; color: #1a2535; }
      .metrica { border-bottom: 1px solid #f0f4f8; padding-bottom: 16px; margin-bottom: 16px; }
      .metrica:last-child { border-bottom: none; padding-bottom: 0; margin-bottom: 0; }
      .metrica-label { font-size: 10px; color: #9aa5b4; font-weight: 600; letter-spacing: .5px; text-transform: uppercase; margin-bottom: 4px; }
      .metrica-row { display: flex; align-items: baseline; gap: 8px; margin-bottom: 6px; }
      .metrica-val { font-family: 'Playfair Display', Georgia, serif; font-size: 28px; font-weight: 700; color: #1a2535; }
      .metrica-uni { font-size: 12px; color: #9aa5b4; font-weight: 500; }
      .badge { font-size: 10px; padding: 2px 8px; border-radius: 20px; font-weight: 700; }
      .badge-ok { background: #e6f7f0; color: #2db88a; }
      .badge-mal { background: #fde8f1; color: #E8317A; }
      .badge-neu { background: #f0f4f8; color: #8a97a8; }
      .barra-wrap { position: relative; margin: 8px 0 28px; }
      .barra-track { position: relative; height: 12px; border-radius: 8px; background: #e8edf5; overflow: visible; }
      .barra-track-inner { position: relative; height: 12px; border-radius: 8px; overflow: hidden; }
      .barra-normal { position: absolute; top: 0; height: 100%; }
      .barra-fill { position: absolute; left: 0; top: 0; height: 100%; border-radius: 8px; }
      .barra-sep { position: absolute; top: -3px; width: 2px; height: 18px; background: rgba(255,255,255,.9); z-index: 2; }
      .barra-labels { position: relative; height: 16px; margin-top: 5px; font-size: 9px; color: #9aa5b4; }
      .barra-labels span { position: absolute; transform: translateX(-50%); white-space: nowrap; }
      .desc { font-size: 11px; color: #9aa5b4; line-height: 1.6; margin-bottom: 10px; }
      .chart-wrap { background: linear-gradient(135deg,#fdf8fc,#fef5f9); border-radius: 12px; padding: 12px 10px 6px; margin-top: 8px; }
      .equil-badge { display: inline-block; padding: 8px 24px; border-radius: 24px; background: linear-gradient(135deg,#fde8f1,#fef3e2); color: #E8317A; font-weight: 700; font-size: 15px; font-family: 'Playfair Display', Georgia, serif; border: 1.5px solid #E8317A; }
      .footer { text-align: center; padding: 16px 18px 8px; font-size: 10px; color: #c8a8b8; }
      .state { text-align: center; padding: 60px 20px; }
      .state-icon { font-size: 40px; margin-bottom: 12px; }
      .wa-btn { display: inline-block; margin-top: 16px; background: #25D366; color: #fff; border-radius: 12px; padding: 10px 20px; font-weight: 600; font-size: 13px; text-decoration: none; }
      .hidden { display: none !important; }
    </style>
  </head>
  <body>

    <div class="header">
      <div class="header-inner">
        <img src="data:image/jpeg;base64," alt="Iratxe Menéndez" style="width:48px;height:48px;object-fit:contain;border-radius:50%;background:#fff;padding:4px;margin-right:12px;flex-shrink:0">
        <div class="logo-text">
          <div class="logo-name">Iratxe Menéndez</div>
          <div class="logo-sub">NUTRICIONISTA · CÉD. PROF. EN TRÁMITE</div>
        </div>
        <div class="score-box">
          <div class="score-lbl">PUNTUACIÓN INBODY</div>
          <div class="score-val" id="score">—</div>
        </div>
      </div>
      <div class="accent-bar"></div>
    </div>

    <div class="pac-band">
      <div>
        <div class="pac-nombre" id="pac-nombre">—</div>
        <div class="pac-info" id="pac-info">—</div>
      </div>
      <div class="pac-fecha">
        <span>Medición</span>
        <strong id="pac-fecha">—</strong>
      </div>
    </div>

    <!-- Estado: cargando -->
    <div id="st-loading" class="state">
      <div class="state-icon">⏳</div>
      <p style="color:#9aa5b4">Cargando tu reporte...</p>
    </div>

    <!-- Estado: error -->
    <div id="st-error" class="state hidden">
      <div class="state-icon">🔍</div>
      <p style="font-weight:600">Reporte no encontrado</p>
      <p style="font-size:12px;color:#9aa5b4;margin-top:6px">El enlace puede haber expirado o no es válido.</p>
      <a href="https://wa.me/5219996690192?text=Hola%20Iratxe%2C%20necesito%20mi%20reporte%20InBody" class="wa-btn">Solicitar reporte por WhatsApp</a>
    </div>

    <!-- Contenido del reporte -->
    <div id="st-report" class="hidden">
      <div class="content">

        <!-- Músculo-Grasa -->
        <div class="card">
          <div class="card-title"><span>💪</span> Análisis Músculo-Grasa</div>
          <div class="metrica">
            <div class="metrica-label">Peso corporal</div>
            <div class="metrica-row">
              <span class="metrica-val" id="v-peso">—</span>
              <span class="metrica-uni">kg</span>
              <span class="badge" id="b-peso"></span>
            </div>
            <div id="bar-peso"></div>
            <p class="desc">El peso es la suma total de los componentes corporales: agua corporal, proteínas, minerales y grasa corporal.</p>
            <div class="chart-wrap"><canvas id="c-peso" height="80"></canvas></div>
          <div id="pct-peso"></div>
          </div>
          <div class="metrica">
            <div class="metrica-label">Músculo esquelético</div>
            <div class="metrica-row">
              <span class="metrica-val" id="v-mus">—</span>
              <span class="metrica-uni">kg</span>
              <span class="badge" id="b-mus"></span>
            </div>
            <div id="bar-mus"></div>
            <p class="desc">Los músculos se dividen en cardíaco, visceral y esquelético. El esquelético está adherido al hueso y es el único que aumenta con el ejercicio. Los músculos son menos voluminosos que la misma cantidad de grasa: con igual peso, más músculo significa verse más fuerte y delgado.</p>
            <div class="chart-wrap"><canvas id="c-mus" height="80"></canvas></div>
          <div id="pct-mus"></div>
          </div>
          <div class="metrica">
            <div class="metrica-label">Grasa corporal</div>
            <div class="metrica-row">
              <span class="metrica-val" id="v-grasa">—</span>
              <span class="metrica-uni">kg</span>
              <span class="badge" id="b-grasa"></span>
            </div>
            <div id="bar-grasa"></div>
            <p class="desc">La grasa corporal incluye tejido adiposo subcutáneo, visceral e intramuscular. Un porcentaje elevado aumenta el riesgo cardiovascular y metabólico independientemente del peso total.</p>
            <div class="chart-wrap"><canvas id="c-grasa" height="80"></canvas></div>
          <div id="pct-grasa"></div>
          </div>
        </div>

<!-- CID -->
        <div class="card">
          <div style="font-size:10px;font-weight:700;color:#9aa5b4;letter-spacing:2px;margin-bottom:4px">CID</div>
          <div id="cid-tipo-title" style="font-family:'Playfair Display',Georgia,serif;font-size:16px;font-weight:700;color:#1a2535;margin-bottom:18px">—</div>
          <div style="margin-bottom:2px">
            <div style="font-size:11px;font-weight:600;color:#4a5568;margin-bottom:0">Peso</div>
            <div id="cid-bar-peso"></div>
          </div>
          <div style="margin-bottom:2px">
            <div style="font-size:11px;font-weight:600;color:#4a5568;margin-bottom:0">Masa de Músculo Esquelético</div>
            <div id="cid-bar-mus"></div>
          </div>
          <div style="margin-bottom:2px">
            <div style="font-size:11px;font-weight:600;color:#4a5568;margin-bottom:0">Grasa Corporal</div>
            <div id="cid-bar-grasa"></div>
          </div>
          <p id="cid-tipo-desc" style="font-size:12px;color:#4a5568;line-height:1.6;margin-top:14px"></p>
        </div>

        <!-- Obesidad -->
        <div class="card">
          <div class="card-title"><span>⚖️</span> Análisis de Obesidad</div>
          <div class="metrica">
            <div class="metrica-label">IMC</div>
            <div class="metrica-row">
              <span class="metrica-val" id="v-imc">—</span>
              <span class="metrica-uni">kg/m²</span>
              <span class="badge" id="b-imc"></span>
            </div>
            <div id="bar-imc"></div>
            <p class="desc">Clasifica la obesidad por peso y altura, sin distinguir músculo de grasa.</p>
            <div class="chart-wrap"><canvas id="c-imc" height="80"></canvas></div>
          <div id="pct-imc"></div>
          </div>
          <div class="metrica">
            <div class="metrica-label">Porcentaje de Grasa Corporal</div>
            <div class="metrica-row">
              <span class="metrica-val" id="v-pgc">—</span>
              <span class="metrica-uni">%</span>
              <span class="badge" id="b-pgc"></span>
            </div>
            <div id="bar-pgc"></div>
            <p class="desc">Rango saludable: 10–20% en hombres · 18–28% en mujeres.</p>
            <div class="chart-wrap"><canvas id="c-pgc" height="80"></canvas></div>
          <div id="pct-pgc"></div>
          </div>
        </div>

        <!-- Tipo de cuerpo -->
        <div class="card">
          <div class="card-title"><span>🧬</span> Coordenada de Tipo de Cuerpo</div>
          <div id="body-grid-label" style="font-size:11px;color:#9aa5b4;margin-bottom:4px">Clasificación</div>
          <div id="body-grid-title" style="font-family:'Playfair Display',Georgia,serif;font-size:17px;font-weight:700;color:#1a2535;margin-bottom:14px">—</div>
          <div id="body-grid"></div>
          <p style="font-size:10px;color:#9aa5b4;margin-top:10px;line-height:1.5" id="cid-desc"></p>
        </div>

        <!-- Obesidad abdominal -->
        <div class="card">
          <div class="card-title"><span>📏</span> Obesidad Abdominal</div>
          <div class="metrica">
            <div class="metrica-label">Relación Cintura-Cadera</div>
            <div class="metrica-row">
              <span class="metrica-val" id="v-cc">—</span>
              <span class="metrica-uni"></span>
              <span class="badge" id="b-cc"></span>
            </div>
            <div id="bar-cc"></div>
            <p class="desc">Riesgo cardiovascular elevado: ICC > 0.90 ♂ · > 0.85 ♀.</p>
            <div class="chart-wrap"><canvas id="c-cc" height="80"></canvas></div>
          </div>
          <div class="metrica">
            <div class="metrica-label">Grasa Visceral</div>
            <div class="metrica-row">
              <span class="metrica-val" id="v-visc">—</span>
              <span class="metrica-uni">Nivel</span>
              <span class="badge" id="b-visc"></span>
            </div>
            <div id="bar-visc"></div>
            <p class="desc">Se recomienda mantener el nivel de grasa visceral por debajo de 10.</p>
            <div class="chart-wrap"><canvas id="c-visc" height="80"></canvas></div>
          </div>
        </div>

        <!-- Análisis Total -->
        <div class="card">
          <div class="card-title"><span>🔥</span> Análisis Total</div>
          <div class="metrica">
            <div class="metrica-label">Tasa Metabólica Basal</div>
            <div class="metrica-row">
              <span class="metrica-val" id="v-tmb">—</span>
              <span class="metrica-uni">kcal</span>
              <span class="badge" id="b-tmb"></span>
            </div>
            <p class="desc">Calorías mínimas para sostener funciones vitales en reposo. Aumenta con más músculo.</p>
            <div class="chart-wrap"><canvas id="c-tmb" height="80"></canvas></div>
          </div>
          <div class="metrica">
            <div class="metrica-label">Masa Magra</div>
            <div class="metrica-row">
              <span class="metrica-val" id="v-magra">—</span>
              <span class="metrica-uni">kg</span>
              <span class="badge" id="b-magra"></span>
            </div>
            <div id="bar-magra"></div>
            <div class="chart-wrap"><canvas id="c-magra" height="80"></canvas></div>
          </div>
        </div>

        <!-- Equilibrio -->
        <div class="card">
          <div class="card-title"><span>⚖️</span> Equilibrio Corporal</div>
          <div style="text-align:center;padding:8px 0">
            <div style="font-size:10px;color:#9aa5b4;margin-bottom:10px;letter-spacing:.5px;text-transform:uppercase">Distribución superior-inferior</div>
            <span class="equil-badge" id="v-equil">—</span>
          </div>
        </div>

        <div class="footer">
          Consultorio Nutriológico Iratxe Menéndez · Cédula Profesional en trámite<br>
          Reporte generado desde menendez.lat · Uso exclusivo del paciente
        </div>

      </div>
    </div>

    <script>
      const APPS_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbxzwjqkcJc85XR-2dzOw3VuFGs3ejF90fsIBcFYVs4EAhe2iM4dwRgff_KTXSBJnRlM/exec';
      const params   = new URLSearchParams(window.location.search);
      const reportId = params.get('id');

      // ── Rangos por sexo y edad ──────────────────────────────────────────────
      function getRangos(sexo, edad) {
        const F = sexo === 'F';
        const e = edad || 25;
        const tablaM = [
          [10,17,{min:15,max:25},{min:4,max:14},{min:8,max:18},{min:38,max:70}],
          [18,29,{min:29,max:37},{min:6,max:18},{min:10,max:20},{min:62,max:82}],
          [30,39,{min:28,max:36},{min:7,max:20},{min:11,max:21},{min:63,max:84}],
          [40,49,{min:26,max:34},{min:8,max:22},{min:12,max:22},{min:64,max:86}],
          [50,59,{min:24,max:32},{min:9,max:24},{min:13,max:24},{min:63,max:85}],
          [60,69,{min:22,max:30},{min:10,max:26},{min:14,max:26},{min:61,max:83}],
          [70,99,{min:20,max:28},{min:10,max:27},{min:15,max:27},{min:58,max:80}],
        ];
        const tablaF = [
          [10,17,{min:12,max:20},{min:8,max:20},{min:14,max:24},{min:35,max:62}],
          [18,29,{min:18,max:26},{min:10,max:18},{min:18,max:28},{min:50,max:68}],
          [30,39,{min:17,max:23},{min:11,max:20},{min:19,max:29},{min:51,max:70}],
          [40,49,{min:16,max:22},{min:12,max:22},{min:20,max:30},{min:52,max:72}],
          [50,59,{min:15,max:21},{min:13,max:24},{min:22,max:32},{min:52,max:73}],
          [60,69,{min:14,max:20},{min:13,max:25},{min:23,max:33},{min:51,max:72}],
          [70,99,{min:13,max:19},{min:13,max:26},{min:24,max:34},{min:49,max:70}],
        ];
        const tabla = F ? tablaF : tablaM;
        const g = tabla.find(r => e >= r[0] && e <= r[1]) || tabla[tabla.length-1];
        return {
          musculo:       { normalMin: g[2].min, normalMax: g[2].max, max: F?38:55 },
          grasa:         { normalMin: g[3].min, normalMax: g[3].max, max: 50 },
          pgc:           { normalMin: g[4].min, normalMax: g[4].max, max: 50 },
          peso:          { normalMin: g[5].min, normalMax: g[5].max, max: F?120:140 },
          masaMagra:     { normalMin: F?38:50,  normalMax: F?52:65,  max: F?80:100 },
          imc:           { normalMin: 18.5,     normalMax: 25,       max: 35 },
          cinturaCadera: F ? { normalMin:.70, normalMax:.85, max:1.3 }
                           : { normalMin:.75, normalMax:.90, max:1.3 },
        };
      }

      // ── Barra de rango ──────────────────────────────────────────────────────
      function renderBarra(containerId, val, rango, colorTipo) {
        const el = document.getElementById(containerId);
        if (!el || val === null || val === undefined) return;
        const pct  = Math.min((val / rango.max) * 100, 100);
        const nAp  = (rango.normalMin / rango.max) * 100;
        const nBp  = (rango.normalMax / rango.max) * 100;
        const fill = colorTipo === 'v'
          ? 'linear-gradient(90deg,#4ecba0,#2db88a)'
          : 'linear-gradient(90deg,#F5A623,#E8317A)';
        const bgN  = colorTipo === 'v' ? '#c8ede0' : '#fde8f1';
        const labelColor = colorTipo === 'v' ? '#2DB88A' : '#E8317A';
        el.innerHTML =
          '<div style="position:relative;margin:10px 0 28px">' +
            '<div style="position:relative;height:12px;border-radius:8px;background:#e8edf5">' +
              '<div style="position:absolute;top:0;left:0;width:100%;height:100%;border-radius:8px;overflow:hidden">' +
                '<div style="position:absolute;top:0;left:' + nAp + '%;width:' + (nBp-nAp) + '%;height:100%;background:' + bgN + '"></div>' +
                '<div style="position:absolute;top:0;left:0;width:' + pct + '%;height:100%;background:' + fill + ';border-radius:8px"></div>' +
              '</div>' +
              '<div style="position:absolute;top:-3px;left:' + nAp + '%;width:2px;height:18px;background:rgba(255,255,255,.9);z-index:2"></div>' +
              '<div style="position:absolute;top:-3px;left:' + nBp + '%;width:2px;height:18px;background:rgba(255,255,255,.9);z-index:2"></div>' +
            '</div>' +
            '<div style="position:relative;height:16px;margin-top:5px;font-size:9px;color:#9aa5b4">' +
              '<span style="position:absolute;left:' + (nAp/2) + '%;transform:translateX(-50%)">Baja</span>' +
              '<span style="position:absolute;left:' + ((nAp+nBp)/2) + '%;transform:translateX(-50%);font-weight:700;color:' + labelColor + '">Normal</span>' +
              '<span style="position:absolute;left:' + ((nBp+100)/2) + '%;transform:translateX(-50%)">Alta</span>' +
            '</div>' +
          '</div>';
      }

      // ── Badge delta ─────────────────────────────────────────────────────────
      function setBadge(id, val, prev, buenBaja) {
        const el = document.getElementById(id);
        if (!el || prev === null || prev === undefined || val === null) { el && (el.textContent = ''); return; }
        const d = +(val - prev).toFixed(1);
        const txt = d > 0 ? '+'+d : String(d);
        const bueno = buenBaja ? d < 0 : d > 0;
        el.textContent = txt;
        el.className = 'badge ' + (d === 0 ? 'badge-neu' : bueno ? 'badge-ok' : 'badge-mal');
      }

      // ── Chart.js mini gráfica ────────────────────────────────────────────────
      function miniChart(id, labels, data, color, rango) {
  const el = document.getElementById(id);
  if (!el) return;
  const vals = data.map(v => v === null || v === undefined ? NaN : v);
  const valid = vals.filter(v => !isNaN(v));
  if (valid.length === 0) return;
  let mn, mx;
  if (rango) {
    const rangeW = rango.normalMax - rango.normalMin;
    const pad = rangeW * 0.08;
    mn = Math.min(Math.min(...valid), rango.normalMin) - pad;
    mx = Math.max(Math.max(...valid), rango.normalMax) + pad;
  } else {
    const spread = Math.max(...valid) - Math.min(...valid);
    mn = Math.min(...valid) - Math.max(spread * 0.3, 1);
    mx = Math.max(...valid) + Math.max(spread * 0.3, 1);
  }
  new Chart(el.getContext('2d'), {
    type: 'line',
    data: { labels, datasets: [{
      data: vals, borderColor: color, borderWidth: 2.5,
      pointBackgroundColor: color, pointRadius: 4, pointHoverRadius: 6,
      tension: .35, fill: true, spanGaps: false,
      backgroundColor: (() => {
        const g = el.getContext('2d').createLinearGradient(0,0,0,80);
        const hex = color.replace('#','');
        const r = parseInt(hex.slice(0,2),16), gv = parseInt(hex.slice(2,4),16), b = parseInt(hex.slice(4,6),16);
        g.addColorStop(0, `rgba(${r},${gv},${b},0.18)`);
        g.addColorStop(1, `rgba(${r},${gv},${b},0)`);
        return g;
      })()
    }]},
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: '#fff', titleColor: '#9aa5b4',
          bodyColor: '#1a2535', borderColor: '#f0e8f4',
          borderWidth: 1, padding: 8, cornerRadius: 8,
          titleFont: { size: 9 }, bodyFont: { size: 12, weight: 'bold' },
          boxWidth: 0, boxHeight: 0
        }
      },
      scales: {
        x: { grid: { display: false }, ticks: { font: { size: 8 }, color: '#9aa5b4', maxRotation: 0 }, border: { display: false } },
        y: { min: mn, max: mx, grid: { color: '#f5edf8' }, ticks: { font: { size: 8 }, color: '#9aa5b4' }, border: { display: false } }
      }
    }
  });
}


      // ── Error function (para CDF normal) ───────────────────────────────────
      function erf(x) {
        const s = x >= 0 ? 1 : -1;
        x = Math.abs(x);
        const t = 1 / (1 + 0.3275911 * x);
        const y = 1 - (((((1.061405429*t - 1.453152027)*t + 1.421413741)*t - 0.284496736)*t + 0.254829592)*t) * Math.exp(-x*x);
        return s * y;
      }

      function calcScore(masaMagra, grasa, alturaCm, sexo) {
        if (!alturaCm || alturaCm < 100) return null;
        const h = alturaCm / 100;
        const pesoStd = h * h * (sexo === 'F' ? 21.5 : 22);
        const lbmStd  = pesoStd * (sexo === 'F' ? 0.77 : 0.85);
        const bfmStd  = pesoStd * (sexo === 'F' ? 0.23 : 0.15);
        const score = Math.round(80 + (masaMagra - lbmStd) * 2 - (grasa - bfmStd) * 2);
        return Math.max(0, Math.min(100, score));
      }

// ── Tabla de referencia poblacional ─────────────────────────────────────────
// Fuente A: Barbão et al. Nutrients 2025, PMC12073220
//           n=8,556 (F=4,628/M=3,928), InBody 570, Brasil, 18–49 años
// Fuente B: Coelho-Júnior et al. Front Public Health 2024, PMC10791914
//           n=18,625, InBody 230, Brasil, 18–80+ años
// Formato filas: [edadMin, edadMax, media, SD]
// ─────────────────────────────────────────────────────────────────────────────
const REFPOP = {
  muscle: {
    F: [[10,17,20.5,2.8],[18,29,25.2,3.0],[30,39,25.7,3.3],[40,49,25.6,3.2],
        [50,59,25.0,3.1],[60,69,23.9,2.7],[70,99,23.5,2.8]],   // Fuente B
    M: [[10,17,27.0,4.5],[18,29,34.7,5.2],[30,39,37.2,5.4],[40,49,37.3,5.2],
        [50,59,35.2,4.8],[60,69,33.3,4.9],[70,99,30.6,4.2]],   // Fuente B
  },
  fat: {
    F: [[10,17,14.0,6.0],[18,29,21.7,9.1],[30,39,26.2,11.0],[40,49,29.2,10.9]], // Fuente A
    M: [[10,17,10.0,5.0],[18,29,16.2,8.2],[30,39,19.9,8.2], [40,49,23.0,8.7]], // Fuente A
  },
  pgc: {
    F: [[10,17,24.0,7.0],[18,29,31.8,8.5],[30,39,32.5,10.6],[40,49,37.9,8.3]], // Fuente A
    M: [[10,17,14.0,6.0],[18,29,19.7,7.9],[30,39,23.3,7.4], [40,49,26.0,7.8]], // Fuente A
  },
  peso: {
    F: [[10,17,55.0,10.0],[18,29,65.7,12.1],[30,39,72.2,14.5],[40,49,74.6,13.9]], // Fuente A
    M: [[10,17,65.0,12.0],[18,29,79.6,11.8],[30,39,83.9,12.5],[40,49,87.6,11.3]], // Fuente A
  },
};

function getRefMeanSD(tipo, rango, sexo, edad) {
  const e = Number(edad) || 25;
  const sx = sexo === 'M' ? 'M' : 'F';
  const table = REFPOP[tipo]?.[sx];
  if (table) {
    const row = table.find(r => e >= r[0] && e <= r[1]) || table[table.length - 1];
    return { mean: row[2], sd: row[3] };
  }
  // Fallback fórmula para IMC y grupos sin datos publicados
  const range = rango.normalMax - rango.normalMin;
  if (tipo === 'imc') return { mean: rango.normalMax, sd: Math.max(range / 1.5, 0.01) };
  return { mean: rango.normalMax, sd: Math.max(range * 0.93, 0.01) };
}

      // ── Histograma de distribución percentil ────────────────────────────────
      function renderPercentil(containerId, val, rango, sexo, edad, color, tipo) {
  const el = document.getElementById(containerId);
  if (!el || val === null || val === undefined) return;

  const { mean, sd } = getRefMeanSD(tipo, rango, sexo, edad);

  const z    = (val - mean) / sd;
  const pct  = Math.round(Math.max(0.1, Math.min(99.9,
                 0.5 * (1 + erf(z / Math.sqrt(2))) * 100)) * 10) / 10;

  const N = 15;
  const rMin = mean - 3.5 * sd;
  const step = (7 * sd) / N;

  const heights = [];
  for (let i = 0; i < N; i++) {
    const x = rMin + (i + 0.5) * step;
    heights.push(Math.exp(-0.5 * ((x - mean) / sd) ** 2));
  }
  const maxH = Math.max(...heights);
  const patIdx = Math.min(N - 1, Math.max(0, Math.floor((val - rMin) / step)));

  const sexoTxt = sexo === 'F' ? 'Femenino' : 'Masculino';

  let barsHTML = '';
  for (let i = 0; i < N; i++) {
    const h   = (heights[i] / maxH) * 72;
    const isP = i === patIdx;
    const bc  = isP ? color : '#dde3ea';
    barsHTML +=
      '<div style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:flex-end;height:88px;position:relative">' +
      (isP ? '<div style="font-size:9px;font-weight:700;color:' + color + ';margin-bottom:2px;white-space:nowrap">' + pct + '%</div>' : '') +
      (i <= 1 || i >= N - 2
        ? '<div style="width:6px;height:6px;border-radius:50%;background:' + bc + ';margin-bottom:' + (72 - h) + 'px"></div>'
        : '<div style="width:70%;background:' + bc + ';height:' + h + 'px;min-height:3px;border-radius:2px 2px 0 0"></div>'
      ) +
      '</div>';
  }
  
        el.innerHTML =
          '<div style="background:#fafbfc;border-radius:12px;padding:12px 10px 8px;margin-top:8px;border:1px solid #f0f0f4">' +
          '<div style="display:flex;align-items:flex-end;gap:1px">' + barsHTML + '</div>' +
          '<div style="display:flex;justify-content:space-between;margin-top:6px;font-size:9px;color:#9aa5b4">' +
          '<span>Bajo</span>' +
          '<span style="font-weight:600;color:#1a2535">' + edad + ' · ' + sexoTxt + '</span>' +
          '<span>Alto</span>' +
          '</div></div>';
      }

function renderCID(peso, musculo, grasa, rangos, imc, pgc, sexo) {
        const titleEl = document.getElementById('cid-tipo-title');
        const descEl  = document.getElementById('cid-tipo-desc');
        if (!titleEl) return;
        const F = sexo === 'F';
        const pgcLo = F ? 18 : 10, pgcHi = F ? 28 : 20;
        const imcHi = 25, imcLo = 18.5;
        let zona, desc;
        if (imc >= imcHi) {
          if (pgc < pgcLo)      { zona='Atlético con Sobrepeso';          desc='IMC elevado por masa muscular. El exceso de peso se explica principalmente por músculo. Mantén el entrenamiento de fuerza y cuida la nutrición.'; }
          else if (pgc < pgcHi) { zona='Sobrepeso';                       desc='Peso y grasa por encima del rango normal. Se recomienda reducir grasa corporal manteniendo la masa muscular mediante ejercicio y alimentación adecuada.'; }
          else                  { zona='Obesidad';                        desc='Peso, grasa y porcentaje de grasa por encima del rango. Alta probabilidad de masa muscular metabólicamente inactiva. Priorizar reducción de grasa y activación muscular.'; }
        } else if (imc >= imcLo) {
          if (pgc < pgcLo)      { zona='Musculoso con Normopeso';          desc='Normopeso con buena masa muscular y bajo porcentaje de grasa. Composición ideal. Continúa con tu rutina de ejercicio y nutrición.'; }
          else if (pgc < pgcHi) { zona='Normopeso Equilibrado';            desc='Peso e índice de masa corporal dentro del rango normal con composición equilibrada. Mantén hábitos saludables de actividad física y alimentación.'; }
          else                  { zona='Débil con Normopeso (Tipo-C)';    desc='El peso se encuentra dentro del rango normal pero el músculo esquelético es insuficiente en relación al peso, por lo que el cuerpo es más débil de lo que parece. Se deriva frecuentemente de baja actividad física, ingesta insuficiente de proteínas o pérdida de proteínas por hipercatabolismo. Se recomienda incrementar el ejercicio de fuerza y la ingesta proteica.'; }
        } else {
          if (pgc < pgcLo)      { zona='Musculoso con Bajo Peso';          desc='Bajo IMC con buena masa muscular relativa. Considera aumentar el aporte calórico de forma controlada para ganar peso con músculo.'; }
          else if (pgc < pgcHi) { zona='Bajo Peso';                        desc='Bajo peso con composición equilibrada. Se recomienda incrementar la ingesta calórica y de proteínas con supervisión nutricional.'; }
          else                  { zona='Bajo Peso con Exceso de Grasa';   desc='Bajo peso con porcentaje de grasa elevado y masa muscular reducida. Requiere atención nutricional prioritaria para reducir grasa e incrementar músculo.'; }
        }
        titleEl.textContent = zona;
        descEl.textContent  = desc;
        renderBarra('cid-bar-peso',  peso,    rangos.peso,    'v');
        renderBarra('cid-bar-mus',   musculo, rangos.musculo, 'v');
        renderBarra('cid-bar-grasa', grasa,   rangos.grasa,   'v');
      }

      // ── Grid de tipo de cuerpo ───────────────────────────────────────────────
      function renderBodyGrid(imc, pgc, sexo) {
        const el    = document.getElementById('body-grid');
        const title = document.getElementById('body-grid-title');
        const desc  = document.getElementById('cid-desc');
        if (!el || imc === null || pgc === null) return;

        const F = sexo === 'F';
        const pgcLo = F ? 18 : 10;
        const pgcHi = F ? 28 : 20;
        const imcHi = 25, imcLo = 18.5;

        // Determinar zona
        let zone, zoneColor, zoneDesc;
        if (imc >= imcHi) {
          if (pgc < pgcLo)      { zone = 'Figura Atlética';        zoneColor = '#e8f2fc'; zoneDesc = 'IMC elevado por masa muscular. Mantén el entrenamiento de fuerza y cuida la nutrición.'; }
          else if (pgc < pgcHi) { zone = 'Sobrepeso';              zoneColor = '#fef3e2'; zoneDesc = 'Peso por encima del rango con grasa moderada. Se recomienda reducir grasa manteniendo músculo.'; }
          else                  { zone = 'Obesidad';               zoneColor = '#fde8f1'; zoneDesc = 'Todos los parámetros por encima del rango. Alta probabilidad de masa muscular metabólicamente inactiva. Reducir grasa y activar músculo con ejercicio.'; }
        } else if (imc >= imcLo) {
          if (pgc < pgcLo)      { zone = 'Figura Musculosa';       zoneColor = '#e6f7f0'; zoneDesc = 'Buena masa muscular con bajo porcentaje de grasa. Continúa con tu rutina actual.'; }
          else if (pgc < pgcHi) { zone = 'Promedio';               zoneColor = '#f0f4f8'; zoneDesc = 'Composición corporal dentro de rangos normales. Mantén hábitos saludables.'; }
          else                  { zone = 'Obesidad Sarcopénica';   zoneColor = '#fef3e2'; zoneDesc = 'IMC normal pero grasa elevada. Recomendable reducir grasa corporal e incrementar actividad física.'; }
        } else {
          if (pgc < pgcLo)      { zone = 'Esbelto Musculoso';      zoneColor = '#e6f7f0'; zoneDesc = 'Bajo IMC con buena masa muscular. Considera aumentar peso con músculo de forma controlada.'; }
          else if (pgc < pgcHi) { zone = 'Esbelto';                zoneColor = '#f0f4f8'; zoneDesc = 'Bajo peso con composición equilibrada. Incrementa la ingesta calórica de forma saludable.'; }
          else                  { zone = 'Grasa Elevada';   zoneColor = '#fde8f1'; zoneDesc = 'Bajo peso con exceso de grasa y poca masa muscular. Requiere atención nutricional prioritaria.'; }
        }

        if (title) title.textContent = zone;
        if (desc)  desc.textContent  = zoneDesc;

        // Construir SVG del grid
        const W = 280, H = 260;
        const padL = 30, padB = 28, padR = 10, padT = 10;
        const gW = W - padL - padR;
        const gH = H - padT - padB;

        // Posición del punto del paciente
        const pgcMin = F ? 10 : 5,  pgcMax = F ? 40 : 35;
        const imcMin = 15,            imcMax = 35;
        const dotX = padL + ((pgc - pgcMin) / (pgcMax - pgcMin)) * gW;
        const dotY = padT + (1 - (imc - imcMin) / (imcMax - imcMin)) * gH;

        // Líneas de separación en el grid
        const xL1 = padL + ((pgcLo - pgcMin) / (pgcMax - pgcMin)) * gW;
        const xL2 = padL + ((pgcHi - pgcMin) / (pgcMax - pgcMin)) * gW;
        const yL1 = padT + (1 - (imcHi - imcMin) / (imcMax - imcMin)) * gH;
        const yL2 = padT + (1 - (imcLo - imcMin) / (imcMax - imcMin)) * gH;

        // Zona destacada del paciente
        let zX, zY, zW2, zH2;
        if (imc >= imcHi)       { zY = padT;  zH2 = yL1 - padT; }
        else if (imc >= imcLo)  { zY = yL1;   zH2 = yL2 - yL1; }
        else                    { zY = yL2;   zH2 = (padT + gH) - yL2; }
        if (pgc < pgcLo)        { zX = padL;  zW2 = xL1 - padL; }
        else if (pgc < pgcHi)   { zX = xL1;   zW2 = xL2 - xL1; }
        else                    { zX = xL2;   zW2 = (padL + gW) - xL2; }

        const zones = [
          { x: padL, y: padT, w: xL1-padL, h: yL1-padT, label: 'Figura|Atlética', fs: 8 },
          { x: xL1,  y: padT, w: xL2-xL1,  h: yL1-padT, label: 'Sobrepeso', fs: 8 },
          { x: xL2,  y: padT, w: padL+gW-xL2, h: yL1-padT, label: 'Obesidad', fs: 9 },
          { x: padL, y: yL1, w: xL1-padL, h: yL2-yL1, label: 'Figura|Musculosa', fs: 7.5 },
          { x: xL1,  y: yL1, w: xL2-xL1,  h: yL2-yL1, label: 'Promedio', fs: 8 },
          { x: xL2,  y: yL1, w: padL+gW-xL2, h: yL2-yL1, label: 'Obesidad|Sarco', fs: 7.5 },
          { x: padL, y: yL2, w: xL1-padL, h: padT+gH-yL2, label: 'Esbelto|Musculoso', fs: 7 },
          { x: xL1,  y: yL2, w: xL2-xL1,  h: padT+gH-yL2, label: 'Esbelto', fs: 8 },
          { x: xL2,  y: yL2, w: padL+gW-xL2, h: padT+gH-yL2, label: 'Obesidad|Sarco.', fs: 7 },
        ];

        let svgZones = '';
        zones.forEach(function(z) {
          const isActive = (z.x === Math.round(zX) || Math.abs(z.x - zX) < 2);
          svgZones += '<rect x="' + z.x.toFixed(1) + '" y="' + z.y.toFixed(1) + '" width="' + z.w.toFixed(1) + '" height="' + z.h.toFixed(1) + '" fill="#f0f4f8" rx="3" stroke="#fff" stroke-width="2"/>';
          const lines = z.label.split('|');
          const cy = z.y + z.h / 2;
          lines.forEach(function(line, li) {
            const ly = cy + (li - (lines.length - 1) / 2) * (z.fs + 2);
            svgZones += '<text x="' + (z.x + z.w/2).toFixed(1) + '" y="' + ly.toFixed(1) + '" text-anchor="middle" font-size="' + z.fs + '" fill="#8a97a8" font-family="DM Sans,Arial,sans-serif" dominant-baseline="middle">' + line + '</text>';
          });
        });

        const svgStr =
          '<svg width="100%" viewBox="0 0 ' + W + ' ' + H + '" xmlns="http://www.w3.org/2000/svg">' +
          svgZones +
          // highlight active zone
          '<rect x="' + zX.toFixed(1) + '" y="' + zY.toFixed(1) + '" width="' + zW2.toFixed(1) + '" height="' + zH2.toFixed(1) + '" fill="' + zoneColor + '" rx="3" stroke="' + (zone.includes('Obes') ? '#E8317A' : '#2DB88A') + '" stroke-width="1.5" opacity="0.9"/>' +
          // grid lines
          '<line x1="' + xL1.toFixed(1) + '" y1="' + padT + '" x2="' + xL1.toFixed(1) + '" y2="' + (padT+gH) + '" stroke="#d0d8e0" stroke-width="1"/>' +
          '<line x1="' + xL2.toFixed(1) + '" y1="' + padT + '" x2="' + xL2.toFixed(1) + '" y2="' + (padT+gH) + '" stroke="#d0d8e0" stroke-width="1"/>' +
          '<line x1="' + padL + '" y1="' + yL1.toFixed(1) + '" x2="' + (padL+gW) + '" y2="' + yL1.toFixed(1) + '" stroke="#d0d8e0" stroke-width="1"/>' +
          '<line x1="' + padL + '" y1="' + yL2.toFixed(1) + '" x2="' + (padL+gW) + '" y2="' + yL2.toFixed(1) + '" stroke="#d0d8e0" stroke-width="1"/>' +
          // axis labels
          '<text x="' + (padL-4) + '" y="' + yL1.toFixed(1) + '" text-anchor="end" font-size="8" fill="#9aa5b4" dominant-baseline="middle">' + imcHi + '</text>' +
          '<text x="' + (padL-4) + '" y="' + yL2.toFixed(1) + '" text-anchor="end" font-size="8" fill="#9aa5b4" dominant-baseline="middle">' + imcLo + '</text>' +
          '<text x="' + xL1.toFixed(1) + '" y="' + (padT+gH+12) + '" text-anchor="middle" font-size="8" fill="#9aa5b4">' + pgcLo + '</text>' +
          '<text x="' + xL2.toFixed(1) + '" y="' + (padT+gH+12) + '" text-anchor="middle" font-size="8" fill="#9aa5b4">' + pgcHi + '</text>' +
          '<text x="' + (padL+gW) + '" y="' + (padT+gH+12) + '" text-anchor="end" font-size="8" fill="#9aa5b4">PGC</text>' +
          '<text x="' + (padL-8) + '" y="' + (padT+gH/2) + '" text-anchor="middle" font-size="8" fill="#9aa5b4" transform="rotate(-90,' + (padL-8) + ',' + (padT+gH/2) + ')">IMC</text>' +
          // dot
          '<circle cx="' + dotX.toFixed(1) + '" cy="' + dotY.toFixed(1) + '" r="6" fill="#E8317A" stroke="#fff" stroke-width="2"/>' +
          '</svg>';

        el.innerHTML = svgStr;
      }

      // ── Cargar reporte ───────────────────────────────────────────────────────
      async function loadReport() {
        if (!reportId) { showError(); return; }
        try {
          const res = await fetch(`${APPS_SCRIPT_URL}?id=${encodeURIComponent(reportId)}`);
          const data = await res.json();
          if (!data || data.error || !data.mediciones || data.mediciones.length === 0) { showError(); return; }

          const meds    = data.mediciones;
          const ultima  = meds[meds.length - 1];
          const prev    = meds.length > 1 ? meds[meds.length - 2] : null;
          const rangos  = getRangos(data.sexo, data.edad);
          const labels  = meds.map(m => m.fechaISO);
          const sexoTxt = data.sexo === 'F' ? 'Femenino' : 'Masculino';

          // Header
          const scoreCalc = data.altura
            ? calcScore(ultima.masaMagra, ultima.grasa, data.altura, data.sexo)
            : null;
          document.getElementById('score').textContent = scoreCalc ?? ultima.score ?? '—';
          document.getElementById('pac-nombre').textContent = data.nombre;
          document.getElementById('pac-info').textContent   = `${sexoTxt} · ${data.edad} años · InBody H30`;
          document.getElementById('pac-fecha').textContent  = ultima.fecha;

          // Función helper para set valor
          function setVal(id, val) {
            document.getElementById(id).textContent = val !== null && val !== undefined ? val : '—';
          }

          // Valores
          setVal('v-peso',  ultima.peso);
          setVal('v-mus',   ultima.musculo);
          setVal('v-grasa', ultima.grasa);
          setVal('v-imc',   ultima.imc);
          setVal('v-pgc',   ultima.pgc);
          setVal('v-cc',    ultima.cc);
          setVal('v-visc',  ultima.visceral);
          setVal('v-tmb',   ultima.tmb);
          setVal('v-magra', ultima.masaMagra);
          document.getElementById('v-equil').textContent = ultima.equil || 'En equilibrio';

          // Badges
          const p = prev;
          setBadge('b-peso',  ultima.peso,      p?.peso,      true);
          setBadge('b-mus',   ultima.musculo,   p?.musculo,   false);
          setBadge('b-grasa', ultima.grasa,     p?.grasa,     true);
          setBadge('b-imc',   ultima.imc,       p?.imc,       true);
          setBadge('b-pgc',   ultima.pgc,       p?.pgc,       true);
          setBadge('b-cc',    ultima.cc,        p?.cc,        true);
          setBadge('b-visc',  ultima.visceral,  p?.visceral,  true);
          setBadge('b-tmb',   ultima.tmb,       p?.tmb,       false);
          setBadge('b-magra', ultima.masaMagra, p?.masaMagra, false);

          // Barras
          renderBarra('bar-peso',  ultima.peso,      rangos.peso,          'v');
          renderBarra('bar-mus',   ultima.musculo,   rangos.musculo,       'v');
          renderBarra('bar-grasa', ultima.grasa,     rangos.grasa,         'v');
          renderBarra('bar-imc',   ultima.imc,       rangos.imc,           'r');
          renderBarra('bar-pgc',   ultima.pgc,       rangos.pgc,           'r');
          renderBarra('bar-cc',    ultima.cc,        rangos.cinturaCadera, 'r');
          renderBarra('bar-visc',  ultima.visceral,  { normalMin:1, normalMax:10, max:20 }, 'r');
          renderBarra('bar-magra', ultima.masaMagra, rangos.masaMagra,     'v');

          // Gráficas
          const ROSA  = '#E8317A', NAR = '#F5A623', VERDE = '#2DB88A';
          miniChart('c-peso',  labels, meds.map(m => m.peso),      ROSA,  rangos.peso);
          miniChart('c-mus',   labels, meds.map(m => m.musculo),   VERDE, rangos.musculo);
          miniChart('c-grasa', labels, meds.map(m => m.grasa),     ROSA,  rangos.grasa);
          miniChart('c-imc',   labels, meds.map(m => m.imc),       NAR,   rangos.imc);
          miniChart('c-pgc',   labels, meds.map(m => m.pgc),       ROSA,  rangos.pgc);
          miniChart('c-cc',    labels, meds.map(m => m.cc),        NAR,   rangos.cinturaCadera);
          miniChart('c-visc',  labels, meds.map(m => m.visceral),  ROSA,  { normalMin:1, normalMax:10 });
          miniChart('c-tmb',   labels, meds.map(m => m.tmb),       VERDE);
          miniChart('c-magra', labels, meds.map(m => m.masaMagra), VERDE, rangos.masaMagra);


          // Percentiles
          renderPercentil('pct-peso',  ultima.peso,    rangos.peso,    data.sexo, data.edad, '#E8317A', 'peso');
          renderPercentil('pct-mus', ultima.musculo, rangos.musculo, data.sexo, data.edad, '#E8317A', 'muscle');
          renderPercentil('pct-grasa', ultima.pgc, rangos.pgc, data.sexo, data.edad, '#E8317A', 'pgc');
          renderPercentil('pct-imc',   ultima.imc,     rangos.imc,     data.sexo, data.edad, '#F5A623', 'imc');
          renderPercentil('pct-pgc',   ultima.pgc,     rangos.pgc,     data.sexo, data.edad, '#E8317A', 'pgc');

          // Grid de tipo de cuerpo
          renderBodyGrid(ultima.imc, ultima.pgc, data.sexo);

          // CID
          renderCID(ultima.peso, ultima.musculo, ultima.grasa, rangos, ultima.imc, ultima.pgc, data.sexo);

          // Mostrar
          document.getElementById('st-loading').classList.add('hidden');
          document.getElementById('st-report').classList.remove('hidden');

        } catch (err) {
          console.error(err);
          showError();
        }
      }

      function showError() {
        document.getElementById('st-loading').classList.add('hidden');
        document.getElementById('st-error').classList.remove('hidden');
      }

      loadReport();
    </script>
  </body>
</html>
