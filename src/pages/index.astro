---
import Container from "@/components/container.astro";
import Cta from "@/components/cta.astro";
import Features from "@/components/features.astro";
import Hero from "@/components/hero.astro";
import Logos from "@/components/logos.astro";
import Layout from "@/layouts/Layout.astro";
---

<Layout title="">
  <Container>
    <Hero />

    <!-- ¿Qué es un chatbot? -->
    <section id="que-es" class="py-16 scroll-mt-24">
      <div class="max-w-3xl mx-auto px-4">
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight">
          ¿Qué es un chatbot?
        </h2>
        <p class="mt-4 text-slate-600">
          🤖 <em>Un chatbot</em> es un asistente virtual que responde mensajes automáticamente en
          <strong>WhatsApp, Instagram y Facebook</strong>, las 24 horas del día, los 7 días de la semana.
        </p>
        <p class="mt-4 text-slate-600">
          Mientras tú duermes, atiendes clientes o te enfocas en tu negocio, <em>tu chatbot</em>:
        </p>
        <ul class="mt-4 space-y-2 text-slate-700 list-none">
          <li>✅ Responde preguntas frecuentes al instante</li>
          <li>✅ Agenda citas y reservaciones automáticamente</li>
          <li>✅ Califica prospectos antes de que lleguen a ti</li>
          <li>✅ Da seguimiento a clientes que no han respondido</li>
          <li>✅ Cierra ventas sin que estés presente</li>
        </ul>
        <p class="mt-4 text-slate-600">
          Y lo mejor... <strong>No reemplaza tu trato personal.</strong> Cuando el cliente necesita hablar contigo
          directamente, el chatbot te avisa al instante.
        </p>
        <p class="mt-4 text-slate-600 italic">
          ¡No esperes más para probar un chatbot de U Link en acción! 😉
        </p>
      </div>
    </section>
    <!-- /¿Qué es un chatbot? -->

    <Features />
    <Logos />

    <!-- Casos de éxito -->
    <section id="casos" class="py-16 scroll-mt-24">
      <div class="max-w-3xl mx-auto px-4">
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight">
          🏆 <em>Casos de éxito</em>
        </h2>
        <p class="mt-4 text-slate-600">
          Actualmente trabajamos con tres negocios piloto donde nuestros chatbots están operando en tiempo real:
        </p>
        <ul class="mt-6 space-y-5 text-slate-700">
          <li>
            <div class="font-semibold">🎨 <em>Estudio Artístico Blanco Terés — Mérida</em></div>
            <p class="text-slate-600">
              Chatbot de WhatsApp, Facebook e Instagram (3 canales) para brindar información, captación de alumnos y agendamiento de clases muestra.
            </p>
          </li>
          <li>
            <div class="font-semibold">🥗 <em>Consultorio Nutriológico Iratxe Menéndez — Mérida</em></div>
            <p class="text-slate-600">
              Chatbot de WhatsApp (1 canal) para información, agendamiento de citas mediante Cal.com y seguimiento de pacientes.
            </p>
          </li>
          <li>
            <div class="font-semibold">🤖 <em>U Link Chatbots — Mérida</em></div>
            <p class="text-slate-600">
              El chatbot de nuestra empresa, que brinda atención por WhatsApp, Facebook e Instagram; comparte información, agenda citas y da aviso para atención en vivo.
            </p>
          </li>
        </ul>
        <p class="mt-6 text-slate-600">
          ¿Quieres ver cómo funciona uno de estos bots en vivo? Con gusto te hacemos una demostración personalizada para tu tipo de negocio.
        </p>
      </div>
    </section>
    <!-- /Casos de éxito -->

    <Cta />
  </Container>
</Layout>
