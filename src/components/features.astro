---
// @ts-ignore
import { Icon } from "astro-icon/components";

const features = [
  {
    title: "Siempre disponible",
    description:
      "Tu chatbot responde al instante, a cualquier hora, en los canales donde ya están tus clientes.",
    icon: "bx:bxs-calendar-check",
  },
  {
    title: "De la consulta al cierre solo",
    description:
      "Califica prospectos, envía información, agenda citas o toma pedidos — sin que intervenga nadie de tu equipo.",
    icon: "bx:bxs-message-square-dots",
  },
  {
    title: "Todo queda registrado",
    description:
      "(En planes Profesional y Total) Cada conversación se guarda en tu CRM automáticamente, listo para dar seguimiento cuando tú decidas.",
    icon: "bx:bxs-data",
  },
];
---

<div class="mt-16 md:mt-0">
  <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight">
    Todo lo que tu negocio necesita para no perder un solo cliente
  </h2>
  <p class="text-lg mt-4 text-slate-600">
    Automatiza conversaciones por WhatsApp, Facebook e Instagram sin contratar más personal.
  </p>
</div>

<div class="grid sm:grid-cols-2 md:grid-cols-3 mt-16 gap-16">
  {
    features.map((item) => (
      <div class="flex gap-4 items-start">
        <div class="mt-1 bg-black rounded-full  p-2 w-8 h-8 shrink-0">
          <Icon class="text-white" name={item.icon} />
        </div>
        <div>
          <h3 class="font-semibold text-lg">{item.title}</h3>{" "}
          <p class="text-slate-500 mt-2 leading-relaxed">{item.description}</p>
        </div>
      </div>
    ))
  }
</div>
