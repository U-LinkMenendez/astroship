---
import Container from "@/components/container.astro";
import Link from "@/components/ui/link.astro";
import Dropdown from "./dropdown.astro";
import { Astronav, MenuItems, MenuIcon } from "astro-navbar";

const menuitems = [
  {
    title: "Presentación",
    path: "#",
    children: [
      { title: "¿Por qué U Link?", path: "/#para-quien" },
      { title: "Casos de Éxito", path: "/#casos" },
      { title: "¿Es para mi negocio?", path: "/#para-quien" },
    ],
  },
  { title: "Paquetes y precios", path: "/pricing" },
  { title: "Acerca de U Link", path: "/about" },
  { title: "Contacto", path: "/contact" },
];
---

<div class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-slate-100">
<Container>
  <header class="flex flex-col lg:flex-row justify-between items-center my-5">
    <Astronav>
      <div class="flex w-full lg:w-auto items-center justify-between">
        <a href="/" class="flex items-center">
          <img src="/logo-ulink.jpeg" alt="U Link Chatbots" class="h-10 w-auto" />
        </a>
        <div class="block lg:hidden">
          <MenuIcon class="w-4 h-4 text-gray-800" />
        </div>
      </div>
      <MenuItems class="hidden w-full lg:w-auto mt-2 lg:flex lg:mt-0">
        <ul class="flex flex-col lg:flex-row lg:gap-3">
          {
            menuitems.map((item, index) => (
              <>
                {item.children && (
                  <Dropdown
                    title={item.title}
                    children={item.children}
                    lastItem={index === menuitems.length - 1}
                  />
                )}

                {!item.children && (
                  <li>
                    <a
                      href={item.path}
                      class="flex lg:px-3 py-2 items-center text-gray-600 hover:text-gray-900">
                      <span>{item.title}</span>
                    </a>
                  </li>
                )}
              </>
            ))
          }
        </ul>
        <div class="lg:hidden flex items-center mt-3 gap-4">
          <Link href="https://wa.me/5219996187124?text=Hola%2C%20me%20gustar%C3%ADa%20conocer%20su%20chatbot%20en%20acci%C3%B3n" size="md" block target="_blank" rel="noopener">
            Conoce nuestro Chatbot
          </Link>
        </div>
      </MenuItems>
    </Astronav>
    <div>
      <div class="hidden lg:flex items-center gap-4">
        <Link href="https://wa.me/5219996187124?text=Hola%2C%20me%20gustar%C3%ADa%20conocer%20su%20chatbot%20en%20acci%C3%B3n" size="md" target="_blank" rel="noopener">
          Conoce nuestro Chatbot
        </Link>
      </div>
    </div>
  </header>
</Container>
</div>

<script>
// Fix 9: close dropdown when clicking outside
document.addEventListener('click', (e) => {
  const dropdowns = document.querySelectorAll('.astronav-dropdown');
  dropdowns.forEach(d => {
    if (!d.contains(e.target)) {
      d.classList.remove('open');
      d.removeAttribute('open');
      d.setAttribute('aria-expanded', 'false');
      const toggle = d.querySelector('.dropdown-toggle');
      if (toggle) {
        toggle.classList.add('hidden');
        toggle.setAttribute('aria-expanded', 'false');
      }
    }
  });
});
</script>
