---
const { title, lastItem, children } = Astro.props;
---

<li class="relative" data-dropdown>
  <button
    type="button"
    aria-expanded="false"
    aria-haspopup="true"
    class="flex items-center gap-1 w-full lg:w-auto lg:px-3 py-2 text-gray-600 hover:text-gray-900">
    <span>{title}</span>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="3"
      class="w-3 h-3 mt-0.5 transition-transform duration-200">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
    </svg>
  </button>

  <div
    data-menu
    class:list={[
      "lg:absolute w-full lg:w-48 z-20",
      lastItem ? "lg:right-0 origin-top-right" : "lg:left-0 origin-top-left",
      "hidden"
    ]}>
    <div class="px-3 lg:py-2 lg:bg-white lg:rounded-md lg:shadow-sm lg:border flex flex-col">
      {children.map((item) => (
        <a href={item.path} class="py-1 text-gray-600 hover:text-gray-900">
          {item.title}
        </a>
      ))}
    </div>
  </div>

  <script>
    // Toggle por clic (funciona en móvil y desktop)
    const root = document.currentScript.closest('li[data-dropdown]');
    const btn = root.querySelector('button[aria-haspopup="true"]');
    const menu = root.querySelector('[data-menu]');
    const icon = btn.querySelector('svg');

    function close() {
      menu.classList.add('hidden');
      btn.setAttribute('aria-expanded', 'false');
      icon.classList.remove('rotate-180');
      document.removeEventListener('click', onDocClick);
      document.removeEventListener('keydown', onKey);
    }
    function open() {
      // Cierra otros abiertos
      document.querySelectorAll('li[data-dropdown] [data-menu]').forEach((m) => m.classList.add('hidden'));
      document.querySelectorAll('li[data-dropdown] button[aria-haspopup="true"]').forEach((b) => b.setAttribute('aria-expanded','false'));
      document.querySelectorAll('li[data-dropdown] button svg').forEach((i) => i.classList.remove('rotate-180'));

      menu.classList.remove('hidden');
      btn.setAttribute('aria-expanded', 'true');
      icon.classList.add('rotate-180');
      document.addEventListener('click', onDocClick);
      document.addEventListener('keydown', onKey);
    }
    function onDocClick(e) {
      if (!root.contains(e.target)) close();
    }
    function onKey(e) {
      if (e.key === 'Escape') close();
    }
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      expanded ? close() : open();
    });
  </script>
</li>
